{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": "./",
    "strict": true,
    "paths": {
      "@core-components": ["src/components/core"],
      "@components": ["src/components"],
      "@containers": ["src/containers"],
      "@theme": ["src/theme"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
