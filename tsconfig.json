{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@core-components": ["./src/ui/components/core"],
      "@components": ["./src/ui/components"],
      "@containers": ["./src/ui/containers"],
      "@screens": ["./src/ui/screens"],
      "@mock-data": ["./src/data"],
      "@theme": ["./src/ui/theme"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
